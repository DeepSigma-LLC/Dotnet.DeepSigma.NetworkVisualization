<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>D3 force-graph JSON renderer for DeepSigma network visualization.</Description>
    <PackageId>DeepSigma.NetworkVisualization.Renderers.D3</PackageId>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>DeepSigma.NetworkVisualization.Renderers.D3</Title>
    <Version>1.0.0</Version>
    <Authors>DeepSigma LLC</Authors>
    <Company>$(Authors)</Company>
    <PackageProjectUrl>https://github.com/DeepSigma-LLC/Dotnet.DeepSigma.NetworkVisualization</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>DeepSigma.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\DeepSigma.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DeepSigma.NetworkVisualization.Core\DeepSigma.NetworkVisualization.Core.csproj" />
  </ItemGroup>

</Project>
